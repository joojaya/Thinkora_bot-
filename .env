# ============================================
# Thinkora AI - Environment Variables
# ============================================

# Flask Secret Key (change this to a random string in production!)
SECRET_KEY=thinkora-secret-key-change-in-production

# Hugging Face API Key (required for Vercel/serverless deployment)
# Get your free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Set to "1" only when deploying on Vercel (leave empty for local)
# VERCEL=1
